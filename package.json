{
  "name": "voice-form-kit",
  "version": "0.1.0",
  "description": "Conversational voice-to-form fill for React / Next.js apps. Two-tier: Web Speech API + AI fallback with multi-turn follow-up.",
  "keywords": ["voice", "form", "speech", "ai", "react", "nextjs"],
  "license": "MIT",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/core/createVoiceFillRoute.ts"
  },
  "peerDependencies": {
    "react": ">=18",
    "@anthropic-ai/sdk": ">=0.100.0",
    "@google/genai": ">=2.0.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": { "optional": true },
    "@google/genai": { "optional": true },
    "openai": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
